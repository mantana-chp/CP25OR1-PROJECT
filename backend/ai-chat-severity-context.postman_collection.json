                ]
              }
            }
          ]
        },
        {
          "name": "4.3 New symptom — respiratory (context rotation to B)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Installation-Id", "value": "{{installationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientChatSessionId\": \"{{sessionMulti}}\",\n  \"query\": \"ตอนนี้น้องเริ่มไอและหายใจเร็ว\",\n  \"contextId\": \"{{contextIdMultiA}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/ai-chat",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "ai-chat"]
            },
            "description": "Different symptom topic (respiratory vs digestive). Expected: contextChanged = true, new contextId (B), contextStatus = pending_severity, severityRequest.reason = new_symptom_context."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json().data || {};",
                  "if (data.contextId) pm.collectionVariables.set('contextIdMultiB', data.contextId);",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Context rotated — contextChanged = true', () => pm.expect(data.contextChanged).to.eql(true));",
                  "pm.test('New contextId (not A)', () => pm.expect(data.contextId).to.not.eql(pm.collectionVariables.get('contextIdMultiA')));",
                  "pm.test('contextStatus is pending_severity', () => pm.expect(data.contextStatus).to.eql('pending_severity'));",
                  "pm.test('severityRequest reason is new_symptom_context', () => pm.expect(data.severityRequest.reason).to.eql('new_symptom_context'));"
                ]
              }
            }
          ]
        },
        {
          "name": "4.4 Submit severity for context B → resolved",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Installation-Id", "value": "{{installationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientChatSessionId\": \"{{sessionMulti}}\",\n  \"query\": \"ตอนนี้น้องเริ่มไอและหายใจเร็ว\",\n  \"contextId\": \"{{contextIdMultiB}}\",\n  \"severitySubmission\": {\n    \"contextId\": \"{{contextIdMultiB}}\",\n    \"level\": 5,\n    \"label\": \"รุนแรงมาก\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/ai-chat",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "ai-chat"]
            },
            "description": "Resolve respiratory context with severity 5. Expected: contextId = B, contextStatus = resolved, severityLevel = 5."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json().data || {};",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Context B resolved', () => pm.expect(data.contextStatus).to.eql('resolved'));",
                  "pm.test('severityLevel is 5', () => pm.expect(data.severityLevel).to.eql(5));",
                  "pm.test('contextId is B not A', () => pm.expect(data.contextId).to.eql(pm.collectionVariables.get('contextIdMultiB')));"
                ]
              }
            }
          ]
        }
      ]
    },
