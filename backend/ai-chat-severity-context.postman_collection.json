{
  "info": {
    "_postman_id": "0f38af7a-5a07-4d4a-a4af-91c5f2f4be5b",
    "name": "AI Chat — Session Scenario Tests",
    "description": "Full scenario coverage for POST /v1/ai-chat using Gemini chat session mode.\nRun requests in order within each folder. Set accessToken and installationId in collection variables before running.\n\nScenarios:\n1. Normal care query (no severity)\n2. Ambiguous health query (clarification returned)\n3. Single symptom flow (pending_severity → resolved → follow-up)\n4. Multi-symptom context rotation (resolved → new symptom → rotation → resolved)\n5. Session continuity (new session fresh start)\n6. Legacy severity text prefix (backward compat)\n7. Mixed continuity — full lifecycle in one session (ambiguous → normal → symptom → resolved → new symptom rotation)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Auto-generate one clientChatSessionId per collection run.",
          "// Each folder that needs a fresh session sets its own variable in its first request.",
          "if (!pm.collectionVariables.get('sessionMain')) {",
          "  pm.collectionVariables.set('sessionMain', pm.variables.replaceIn('{{$guid}}'));",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Scenario 1 — Normal Care Query",
      "item": [
        {
          "name": "1.1 Normal care — no severity",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Installation-Id", "value": "{{installationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientChatSessionId\": \"{{sessionMain}}\",\n  \"query\": \"ควรให้อาหารแมววันละกี่มื้อ\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/ai-chat",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "ai-chat"]
            },
            "description": "Routine care question. Expected: contextStatus = not_required, no severityRequest, no clarificationRequest."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json().data || {};",
                  "if (data.contextId) pm.collectionVariables.set('contextIdMain', data.contextId);",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('contextStatus is not_required', () => pm.expect(data.contextStatus).to.eql('not_required'));",
                  "pm.test('No severityRequest', () => pm.expect(data.severityRequest).to.be.undefined);",
                  "pm.test('No clarificationRequest', () => pm.expect(data.clarificationRequest).to.be.undefined);",
                  "pm.test('Answer present', () => pm.expect(data.answer).to.be.a('string').with.length.above(0));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Scenario 2 — Ambiguous Health Clarification",
      "item": [
        {
          "name": "2.1 Ambiguous query — fresh session triggers clarification",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Installation-Id", "value": "{{installationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientChatSessionId\": \"{{sessionAmbiguous}}\",\n  \"query\": \"น้องดูไม่ปกติ ไม่ค่อยสบาย\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/ai-chat",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "ai-chat"]
            },
            "description": "Vague symptom on a fresh session. Expected: contextStatus = pending_clarification, clarificationRequest present, fast response (no Gemini chat session call)."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Fresh session for this scenario",
                  "pm.collectionVariables.set('sessionAmbiguous', pm.variables.replaceIn('{{$guid}}'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json().data || {};",
                  "if (data.contextId) pm.collectionVariables.set('contextIdAmbiguous', data.contextId);",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('contextStatus is pending_clarification', () => pm.expect(data.contextStatus).to.eql('pending_clarification'));",
                  "pm.test('clarificationRequest present', () => pm.expect(data.clarificationRequest).to.be.an('object'));",
                  "pm.test('clarificationRequest has options', () => pm.expect(data.clarificationRequest.options).to.be.an('array').with.length.above(0));",
                  "pm.test('No severityRequest', () => pm.expect(data.severityRequest).to.be.undefined);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Scenario 3 — Single Symptom Severity Flow",
      "item": [
        {
          "name": "3.1 Start symptom — severity requested",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Installation-Id", "value": "{{installationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientChatSessionId\": \"{{sessionSingle}}\",\n  \"query\": \"น้องหมาอาเจียนตั้งแต่เช้า ไม่ค่อยกินอาหาร\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/ai-chat",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "ai-chat"]
            },
            "description": "Clear symptom (vomiting). Expected: contextStatus = pending_severity, severityRequest present with reason = symptom_needs_assessment."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('sessionSingle', pm.variables.replaceIn('{{$guid}}'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json().data || {};",
                  "if (data.contextId) pm.collectionVariables.set('contextIdA', data.contextId);",
                  "if (data.resolvedPetId) pm.collectionVariables.set('resolvedPetId', data.resolvedPetId);",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('contextStatus is pending_severity', () => pm.expect(data.contextStatus).to.eql('pending_severity'));",
                  "pm.test('severityRequest present', () => pm.expect(data.severityRequest).to.be.an('object'));",
                  "pm.test('severityRequest reason is symptom_needs_assessment', () => pm.expect(data.severityRequest.reason).to.eql('symptom_needs_assessment'));",
                  "pm.test('contextId saved', () => pm.expect(pm.collectionVariables.get('contextIdA')).to.be.a('string'));"
                ]
              }
            }
          ]
        },
        {
          "name": "3.2 Submit severity → context resolved",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Installation-Id", "value": "{{installationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientChatSessionId\": \"{{sessionSingle}}\",\n  \"query\": \"น้องหมาอาเจียนตั้งแต่เช้า ไม่ค่อยกินอาหาร\",\n  \"contextId\": \"{{contextIdA}}\",\n  \"severitySubmission\": {\n    \"contextId\": \"{{contextIdA}}\",\n    \"level\": 4,\n    \"label\": \"รุนแรง\"\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/ai-chat",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "ai-chat"]
            },
            "description": "Submit severity level 4 for the vomiting context. Expected: contextStatus = resolved, severityLevel = 4."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json().data || {};",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('contextStatus is resolved', () => pm.expect(data.contextStatus).to.eql('resolved'));",
                  "pm.test('severityLevel is 4', () => pm.expect(data.severityLevel).to.eql(4));",
                  "pm.test('No severityRequest', () => pm.expect(data.severityRequest).to.be.undefined);",
                  "pm.test('contextId unchanged', () => pm.expect(data.contextId).to.eql(pm.collectionVariables.get('contextIdA')));"
                ]
              }
            }
          ]
        },
        {
          "name": "3.3 Follow-up after resolved — NOT re-triggered as ambiguous",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Installation-Id", "value": "{{installationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientChatSessionId\": \"{{sessionSingle}}\",\n  \"query\": \"ต้องเฝ้าดูอาการอีกกี่ชั่วโมงดี\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/ai-chat",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "ai-chat"]
            },
            "description": "Follow-up question that contains 'อาการ' (health keyword). With resolved context, must NOT trigger clarification. Expected: contextStatus = resolved, Gemini answers with session context."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json().data || {};",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('contextStatus stays resolved (no false clarification)', () => pm.expect(data.contextStatus).to.eql('resolved'));",
                  "pm.test('No clarificationRequest', () => pm.expect(data.clarificationRequest).to.be.undefined);",
                  "pm.test('No severityRequest', () => pm.expect(data.severityRequest).to.be.undefined);",
                  "pm.test('Answer is a contextual follow-up', () => pm.expect(data.answer).to.be.a('string').with.length.above(0));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
