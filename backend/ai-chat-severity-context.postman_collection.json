              "raw": "{{baseUrl}}/v1/ai-chat",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "ai-chat"]
            },
            "description": "User has duplicate pet names (owns 'จิ๊กโก๋' and caregiver for another 'จิ๊กโก๋'). Expected: petContextStatus = pending_clarification, petClarificationRequest with reason = ambiguous_pet_name and 2 options."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.collectionVariables.set('sessionPetAmbiguous', pm.variables.replaceIn('{{$guid}}'));"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json().data || {};",
                  "if (data.contextId) pm.collectionVariables.set('ctxPetAmbiguous', data.contextId);",
                  "if (data.petClarificationRequest?.options?.[0]?.petId) pm.collectionVariables.set('petIdOwned', data.petClarificationRequest.options[0].petId);",
                  "if (data.petClarificationRequest?.options?.[1]?.petId) pm.collectionVariables.set('petIdCaregiver', data.petClarificationRequest.options[1].petId);",
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('petContextStatus is pending_clarification', () => pm.expect(data.petContextStatus).to.eql('pending_clarification'));",
                  "pm.test('petClarificationRequest present', () => pm.expect(data.petClarificationRequest).to.be.an('object'));",
                  "pm.test('petClarificationRequest reason is ambiguous_pet_name', () => pm.expect(data.petClarificationRequest.reason).to.eql('ambiguous_pet_name'));",
                  "pm.test('Options has 2 pets', () => pm.expect(data.petClarificationRequest.options).to.have.lengthOf(2));",
                  "pm.test('First option is OWNER', () => pm.expect(data.petClarificationRequest.options[0].role).to.eql('OWNER'));",
