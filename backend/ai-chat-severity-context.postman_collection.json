    {
      "name": "Scenario 7 — Mixed Continuity (Full Lifecycle in One Session)",
      "item": [
        {
          "name": "7.1 Ambiguous query — clarification returned",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" },
              { "key": "X-Installation-Id", "value": "{{installationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientChatSessionId\": \"{{sessionMixed}}\",\n  \"query\": \"น้องไม่ค่อยสบาย มีอาการแปลกๆ ไม่รู้เป็นอะไร\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/ai-chat",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "ai-chat"]
            },
            "description": "Fresh session, vague symptom. Expected: pending_clarification, clarificationRequest with options list."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
