              { "key": "X-Installation-Id", "value": "{{installationId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"clientChatSessionId\": \"{{sessionMulti}}\",\n  \"query\": \"น้องหมาอาเจียนตั้งแต่เช้า\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/v1/ai-chat",
              "host": ["{{baseUrl}}"],
              "path": ["v1", "ai-chat"]
            },
            "description": "First symptom in the session. Expected: pending_severity, context A created."
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
