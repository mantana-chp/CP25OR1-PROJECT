                  "pm.test('contextStatus is resolved (legacy format parsed)', () => pm.expect(data.contextStatus).to.eql('resolved'));",
                  "pm.test('severityLevel is 3', () => pm.expect(data.severityLevel).to.eql(3));",
                  "pm.test('No severityRequest', () => pm.expect(data.severityRequest).to.be.undefined);"
                ]
              }
            }
          ]
        }
      ]
    }
  ],
