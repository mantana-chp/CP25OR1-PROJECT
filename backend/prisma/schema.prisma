generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL") // just leave it like this (it is just a recommendaion)
}

model breeds {
  id             String  @id @db.Uuid
  species_id     String  @db.Uuid
  name           String  @db.VarChar
  description    String?
  name_th        String  @db.VarChar
  description_th String?
  species        species @relation(fields: [species_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pets           pets[]
}

model notifications {
  id          String              @id @db.Uuid
  user_id     String              @db.Uuid
  reminder_id String?             @db.Uuid
  pet_id      String?             @db.Uuid
  sent_at     DateTime?           @db.Timestamptz(6)
  status      notification_status
  read_at     DateTime?           @db.Timestamptz(6)
  created_at  DateTime?           @default(now()) @db.Timestamptz(6)
  tips_title  String?
  tips_desc   String?
  retry_count Int                 @default(0)
  reminders   reminders?          @relation(fields: [reminder_id], references: [id], onUpdate: NoAction)
  user        users               @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  pet         pets?               @relation(fields: [pet_id], references: [id], onDelete: Cascade)
}

model pets {
  id                  String           @id @default(uuid()) @db.Uuid
  user_id             String           @db.Uuid
  species_id          String           @db.Uuid
  breed_id            String?          @db.Uuid
  pet_name            String           @db.VarChar
  gender              pet_gender       @default(unknown)
  birth_date          DateTime?        @db.Date
  weight              Decimal?         @db.Decimal
  profile_image_key   String?          @db.VarChar  // MinIO object key
  status              pet_status       @default(ACTIVE)
  deceased_date       DateTime?        @db.Date
  deleted_at          DateTime?        @db.Timestamptz(6)
  deletion_reason     deletion_reason?
  created_at          DateTime         @default(now()) @db.Timestamptz(6)
  updated_at          DateTime         @updatedAt @db.Timestamptz(6)
  breeds              breeds?          @relation(fields: [breed_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  species             species          @relation(fields: [species_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user                users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reminders           reminders[]
  notifications       notifications[]
  // Pet sharing relations
  invite_pets         pet_share_invite_pets[]
  user_access         pet_user_access[]
}

model push_tokens {
  id           String    @id @db.Uuid
  user_id      String    @db.Uuid
  token        String    @unique
  last_seen_at DateTime? @db.Timestamptz(6)
  created_at   DateTime  @default(now()) @db.Timestamptz(6)
  user         users     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model reminders {
  id                 String           @id @default(uuid()) @db.Uuid
  user_id            String           @db.Uuid
  pet_id             String           @db.Uuid
  reminder_name      String           @db.VarChar
  description        String?
  reminder_date      DateTime         @db.Date
  reminder_time      DateTime?        @db.Time(6)
  reminder_status    reminder_status  @default(to_do)
  status_done_at     DateTime?        @db.Timestamptz(6)
  created_at         DateTime         @default(now()) @db.Timestamptz(6)
  updated_at         DateTime         @updatedAt @db.Timestamptz(6)
  status_before_done reminder_status?
  category_name      category_name    @default(General)
  is_health          Boolean          @default(false)

  // Relations
  notifications      notifications[]
  pets               pets             @relation(fields: [pet_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  user               users            @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)

  // --- Recurrence (NEW: Links to recurrence template) ---
  recurrence_id      String?          @db.Uuid
  recurrence_template recurrence?     @relation(fields: [recurrence_id], references: [id], onDelete: SetNull)

  // --- EXISTING relationship for vaccines ---
  parent_id          String?          @db.Uuid
  parent             reminders?       @relation("ReminderHierarchy", fields: [parent_id], references: [id], onDelete: Cascade)
  children           reminders[]      @relation("ReminderHierarchy")

  // --- Attachments ---
  reminder_attachments reminder_attachments[]

  // --- Creator tracking (actual user who called the API, may differ from user_id when caregiver creates) ---
  created_by_user_id  String?   @db.Uuid
}

model reminder_attachments {
  id          String    @id @default(uuid()) @db.Uuid
  reminder_id String    @db.Uuid
  object_key  String    @db.VarChar
  file_name   String    @db.VarChar
  file_type   String    @db.VarChar
  file_size   Int
  created_at  DateTime  @default(now()) @db.Timestamptz(6)
  reminders   reminders @relation(fields: [reminder_id], references: [id], onDelete: Cascade)
}

model recurrence {
  id                  String                @id @default(uuid()) @db.Uuid
  
  // --- Series Metadata (NEW) ---
  reminder_name       String?               @db.VarChar
  description         String?
  category_name       category_name?
  recurrence_status   RecurrenceStatusEnum  @default(ACTIVE)

  // Recurrence Pattern
  frequency           RecurrenceFrequency
  interval            Int                   @default(1)
  reminder_time       DateTime?             @db.Time(6) @map("reminder_time")
  daysOfWeek          Int?                  @map("days_of_week")
  dayOfMonth          Int?                  @map("day_of_month")
  template_start_date DateTime              @db.Date  @map("template_start_date")
  
  // End Condition
  endDate             DateTime?             @db.Date  @map("end_date")
  endAfterOccurrences Int?                  @map("end_after_occurrences")

  created_at          DateTime              @default(now()) @db.Timestamptz(6)
  updated_at          DateTime              @updatedAt @db.Timestamptz(6)

  // --- Relation to reminders instances ---
  reminders           reminders[]

  @@map("recurrences")
}

model sessions {
  id                     String     @id @db.Uuid
  user_id                String     @db.Uuid
  jti                    String     @unique
  device_installation_id String?
  created_at             DateTime   @default(now()) @db.Timestamptz(6)
  expires_at             DateTime   @db.Timestamptz(6)
  replaced_by            String?    @db.Uuid
  sessions               sessions?  @relation("sessionsTosessions", fields: [replaced_by], references: [id], onDelete: NoAction, onUpdate: NoAction)
  other_sessions         sessions[] @relation("sessionsTosessions")
  user                   users      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

model species {
  id             String   @id @db.Uuid
  name           String   @unique @db.VarChar
  description    String?
  name_th        String   @unique @db.VarChar
  description_th String?
  breeds         breeds[]
  pets           pets[]
  vaccine        vaccine[]
}

model vaccine {
  id                           Int                @id @default(autoincrement())
  species_id                   String             @db.Uuid
  vaccine_name                 String
  vaccine_name_th              String?
  vaccine_type                 VaccineCategory
  min_age_days                 Int                @default(0)
  primary_series_logic         VaccineLogicType
  primary_interval_days        Int                @default(0)
  primary_target_value         Int
  adult_primary_dose_count     Int                @default(1)
  booster_1_interval_days      Int
  booster_repeat_interval_days Int
  reference_source             String?
  created_at                   DateTime           @default(now()) @db.Timestamptz(6)
  updated_at                   DateTime           @default(now()) @db.Timestamptz(6)

  species species @relation(fields: [species_id], references: [id], onDelete: Cascade)

  @@unique([species_id, vaccine_name])
  @@map("vaccine")
}

model users {
  id                         String             @id @db.Uuid
  status                     user_status        @default(active)
  current_installation_id    String             @unique
  current_platform           platform
  current_platform_device_id String
  current_platform_id_source platform_id_source @default(unknown)
  created_at                 DateTime           @db.Timestamptz(6)
  updated_at                 DateTime?          @db.Timestamptz(6)
  last_active_at             DateTime?          @db.Timestamptz(6)
  notifications              notifications[]
  pets                       pets[]
  push_tokens                push_tokens[]
  reminders                  reminders[]
  sessions                   sessions[]
  // Pet sharing relations
  owned_contacts             owner_caregiver_contacts[] @relation("OwnedContacts")
  caregiver_contacts         owner_caregiver_contacts[] @relation("CaregiverContacts")
  created_invites            pet_share_invites[]        @relation("CreatedInvites")
  claimed_invites            pet_share_invites[]        @relation("ClaimedInvites")
  pet_access                 pet_user_access[]          @relation("AccessiblePets")
  granted_access             pet_user_access[]          @relation("GrantedAccess")
}

enum device_type {
  phone
  tablet
  other
}

enum notification_status {
  sent
  pending
  failed
}

enum pet_gender {
  male
  female
  unknown
}

enum platform {
  ios
  android
  other
}

enum platform_id_source {
  ios_keychain
  android_ssaid
  unknown
}

enum reminder_status {
  to_do
  done
  overdue
  cancelled
}

enum user_status {
  active
  disabled
}

enum category_name {
  General     @map("ทั่วไป")
  Vaccination @map("วัคซีน")
  Checkup     @map("ตรวจสุขภาพ")
  Medication  @map("ยา/อาหารเสริม")
  Deworming   @map("พยาธิ/เห็บหมัด")
  Grooming    @map("ความสะอาดและกรูมมิ่ง")
  Feeding     @map("ให้อาหาร")
}

enum RecurrenceFrequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum RecurrenceStatusEnum {
  ACTIVE
  INACTIVE
  CANCELLED
}

enum pet_status {
  ACTIVE
  DECEASED
  DELETED
}

enum deletion_reason {
  JUST_DELETE
  DECEASED
}

enum VaccineLogicType {
  UNTIL_AGE
  FIXED_COUNT
}

enum VaccineCategory {
  core
  non_core
}

enum invite_status {
  PENDING
  ACCEPTED
  EXPIRED
}

// ─── Pet Sharing Models ───────────────────────────────────────────────────────

model owner_caregiver_contacts {
  id                String   @id @default(uuid()) @db.Uuid
  owner_user_id     String   @db.Uuid
  caregiver_user_id String   @db.Uuid
  alias             String   @db.VarChar(100)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @updatedAt @db.Timestamptz(6)

  owner           users             @relation("OwnedContacts", fields: [owner_user_id], references: [id], onDelete: Cascade)
  caregiver       users             @relation("CaregiverContacts", fields: [caregiver_user_id], references: [id], onDelete: Cascade)
  pet_user_access pet_user_access[]

  @@unique([owner_user_id, caregiver_user_id])
}

model pet_share_invites {
  id              String        @id @default(uuid()) @db.Uuid
  created_by      String        @db.Uuid
  caregiver_alias String        @db.VarChar(100)
  expires_at      DateTime      @db.Timestamptz(6)
  status          invite_status @default(PENDING)
  claimed_by      String?       @db.Uuid
  claimed_at      DateTime?     @db.Timestamptz(6)
  created_at      DateTime      @default(now()) @db.Timestamptz(6)

  creator         users                  @relation("CreatedInvites", fields: [created_by], references: [id])
  claimer         users?                 @relation("ClaimedInvites", fields: [claimed_by], references: [id])
  invite_pets     pet_share_invite_pets[]
  pet_user_access pet_user_access[]
}

model pet_share_invite_pets {
  invite_id String @db.Uuid
  pet_id    String @db.Uuid

  invite pet_share_invites @relation(fields: [invite_id], references: [id], onDelete: Cascade)
  pet    pets              @relation(fields: [pet_id], references: [id], onDelete: Cascade)

  @@id([invite_id, pet_id])
}

model pet_user_access {
  id              String    @id @default(uuid()) @db.Uuid
  pet_id          String    @db.Uuid
  user_id         String    @db.Uuid
  role            String    @default("CAREGIVER") @db.VarChar(50)
  contact_id      String    @db.Uuid
  granted_by      String    @db.Uuid
  granted_at      DateTime  @default(now()) @db.Timestamptz(6)
  revoked_at      DateTime? @db.Timestamptz(6)
  invite_id       String?   @db.Uuid
  installation_id String?   @db.VarChar

  pet     pets                     @relation(fields: [pet_id], references: [id], onDelete: Cascade)
  user    users                    @relation("AccessiblePets", fields: [user_id], references: [id], onDelete: Cascade)
  grantor users                    @relation("GrantedAccess", fields: [granted_by], references: [id])
  contact owner_caregiver_contacts @relation(fields: [contact_id], references: [id])
  invite  pet_share_invites?       @relation(fields: [invite_id], references: [id])

  @@unique([pet_id, user_id])
}
