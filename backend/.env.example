DATABASE_URL=

# JWT Access Token
JWT_SECRET=
JWT_EXPIRES_IN=15m

# JWT Refresh Token
REFRESH_TOKEN_SECRET=
REFRESH_TOKEN_EXPIRES_IN=30d

# API keys
GOOGLE_API_KEY=
PINECONE_API_KEY=
PINECONE_INDEX_NAME=

# ===== MinIO Object Storage Configuration =====
# Root credentials for MinIO server (YOU choose these)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# Connection settings
# LOCAL: Use "localhost" when connecting from host machine
# DOCKER: Use "minio" (service name) when backend runs in Docker
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_USE_SSL=false

# Bucket configuration
# DEV:  dev-pet-attachments
# PROD: prod-pet-attachments
MINIO_BUCKET_NAME=dev-pet-attachments

# Public URL configuration (for presigned URLs)
# LOCAL: http://localhost:9000 (when MinIO ports are exposed for testing)
# PRODUCTION: https://yourdomain.com/storage (proxied through Nginx)
MINIO_PUBLIC_URL=http://localhost:9000